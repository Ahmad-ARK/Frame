# ── LLM + vision backend ──
# "gemini" (default) uses the Google API; "qwen" routes LLM + vision calls to your
# self-hosted Qwen2.5-VL endpoint on Modal (no rate caps). See pipeline/modal/qwen_vl_app.py.
LLM_PROVIDER=gemini


# Google AI Studio API key (https://aistudio.google.com/apikey).
# Required for LLM_PROVIDER=gemini; NOT needed when LLM_PROVIDER=qwen.
GEMINI_API_KEY=your-key-here
# Optional: override the default Gemini model
# GEMINI_MODEL=gemini-2.0-flash

# Self-hosted Qwen2.5-VL endpoint (required when LLM_PROVIDER=qwen).
# QWEN_ENDPOINT=https://<your-modal-username>--qwen-vl-qwenvl-generate.modal.run
# Proxy-auth token from the Modal account the Qwen endpoint is deployed on. Only
# needed if that's a DIFFERENT account than FLUX; otherwise FLUX_MODAL_KEY/SECRET
# below are reused. (Create at: that account's dashboard → Settings → Proxy Auth Tokens.)
# QWEN_MODAL_KEY=your-qwen-account-modal-key
# QWEN_MODAL_SECRET=your-qwen-account-modal-secret

# FLUX.1-dev image generation (self-hosted on Modal) — for genImage scenes.
# Create a token pair in Modal → Settings → Proxy Auth Tokens.
FLUX_MODAL_KEY=your-modal-key
FLUX_MODAL_SECRET=your-modal-secret
# Your Modal web endpoint URL (required for genImage scenes)
FLUX_ENDPOINT=https://<your-modal-username>--flux-api-model-web.modal.run
