# Google AI Studio API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-key-here

# Optional: override the default model (free-tier friendly)
# GEMINI_MODEL=gemini-2.0-flash

# FLUX.1-dev image generation (self-hosted on Modal) — for genImage scenes.
# Create a token pair in Modal → Settings → Proxy Auth Tokens.
FLUX_MODAL_KEY=your-modal-key
FLUX_MODAL_SECRET=your-modal-secret
# Optional: override the endpoint
# FLUX_ENDPOINT=https://ahmadkhalid236997--flux-api-model-web.modal.run
