    {
      "id": "s3-turning-points",
      "narration": "Three dates changed everything. 1979, the invasion. 1989, the retreat. 2001, the blowback.",
      "visual": {
        "type": "timeline",
        "directive": "Three pivotal turning points.",
        "style": {
          "timeline": {
            "mode": "milestones",
            "events": [
