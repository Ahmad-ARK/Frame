  "topic": "The Arc of the Afghan Wars",
  "thesis": "Time tells the story.",
  "scenes": [
    {
      "id": "s1-decade",
      "narration": "The war unfolded over a decade. Operation Cyclone began in July 1979. The Soviets invaded that December. The CIA sent Stinger missiles in 1986. And the last Soviet troops withdrew in February 1989.",
      "visual": {
        "type": "timeline",
        "directive": "The key events of the war in sequence, with detail.",
        "style": {
          "timeline": {
            "mode": "vertical",
            "heading": "A Decade of War",
            "events": [
              {
                "date": "July 1979",
                "title": "Operation Cyclone Begins",
                "description": "The CIA launches its covert program to arm and fund Afghan mujahideen fighting Soviet influence.",
                "color": "accent"
              },
              {
                "date": "December 1979",
                "title": "Soviet Invasion",
                "description": "Soviet troops pour across the border into Afghanistan, triggering a decade-long occupation.",
                "color": "primary"
              },
              {
                "date": "1986",
                "title": "Stinger Missiles Delivered",
                "description": "The CIA supplies Stinger surface-to-air missiles to the mujahideen, shifting the balance of air power.",
                "color": "accent"
              },
              {
                "date": "February 1989",
                "title": "Soviet Withdrawal",
                "description": "The last Soviet troops cross the Friendship Bridge out of Afghanistan, ending the occupation.",
                "color": "primary"
              }
            ]
          }
        },
