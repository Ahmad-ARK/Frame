{
  "compilerOptions": {
    "lib": ["dom", "esnext"],
    "module": "CommonJS",
    "target": "ES2020",
    "jsx": "react",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "./dist"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "remotion.config.ts"]
}
