# ── secrets — NEVER commit ──
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# ── dependencies ──
node_modules/
**/node_modules/

# ── build output ──
dist/
**/dist/
.next/
**/.next/

# ── caches ──
.cache/
**/.cache/

# ── generated / downloaded media (large, regenerate via the pipeline) ──
remotion/out/
remotion/public/assets/
remotion/public/audio/

# ── pipeline intermediate artifacts (storyboards, prompt dumps, llm json) ──
pipeline/out/

# ── OS / editor ──
.DS_Store
Thumbs.db
*.log
